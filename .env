# arcgs environment configuration
ONEAPI_ROOT=C:\bin\Intel\oneAPI
COLMAP_PATH="C:/bin/colmap-x64-windows-nocuda/bin/colmap.exe"

# Copy this file to .env and fill in the paths for your machine.
# arcgs loads .env automatically on every run — no shell setup needed.
#
# Each variable accepts either:
#   - a directory containing the binary  (e.g. C:\bin\ffmpeg\bin)
#   - the full path to the binary itself (e.g. C:\bin\ffmpeg\bin\ffmpeg.exe)
#
# Leave a variable unset to fall back to PATH lookup.

# ── External tools ─────────────────────────────────────────────────────────────

# ffmpeg + ffprobe (frame extraction & video probing)
# Windows: winget install ffmpeg  or  https://ffmpeg.org/download.html
FFMPEG_PATH=C:\bin\ffmpeg\bin
FFPROBE_PATH=C:\bin\ffmpeg\bin

# COLMAP (structure from motion)
# Windows: https://github.com/colmap/colmap/releases  (portable .zip)

# OpenSplat (3DGS training)
# NVIDIA:    https://github.com/pierotofy/OpenSplat/releases
# Intel Arc: build from source with oneAPI SYCL support
OPENSPLAT_PATH=C:\bin\opensplat-src\build\Release

# ── PyTorch / compute backend ──────────────────────────────────────────────────

# Force a specific compute backend (xpu | cuda | directml | cpu).
# Leave unset for auto-detection (XPU → CUDA → DirectML → CPU).
#ARCGS_DEVICE=xpu
